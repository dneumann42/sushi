{
  "name": "sushi-language",
  "displayName": "Sushi Language",
  "description": "Syntax highlighting and editor basics for Sushi source files.",
  "version": "0.0.1",
  "publisher": "dneumann42",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sushi",
        "aliases": [
          "Sushi",
          "sushi"
        ],
        "extensions": [
          ".sushi"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sushi",
        "scopeName": "source.sushi",
        "path": "./syntaxes/sushi.tmLanguage.json"
      }
    ]
  }
}
