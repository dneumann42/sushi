use pen global

var styles "
  body {
    margin: 0;
  }
  h1, h2, h3, h4, h5, h6 {
    margin: 0;
  }
  .hbox {
    display: flex;
    flex-direction: row;
    gap: 16px;
  }
  .vbox {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .align-center { align-items: center; }
"

fun page-header [title] do
  doc-string \\
    header { class "hbox" } \\
      h1 { } title
      nav { class "hbox align-center" } \\
        a { href "#" } "Test"
        a { href "#" } "About"
        a { href "#" } "Help"
end

fun page [page-title slot] do
  doc-string \\
    html { lang "en" } \\
      head {} \\
        title-tag { } page-title
        style { } styles
      body {} \\
        @ [page-header "Sushi"]
        @ slot
end

doc Main \\
  @ [page "Sushi" [doc-string \\
    h1 "Hello"
  ]]
  