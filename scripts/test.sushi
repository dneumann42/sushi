use io

fun throw-error [] do
  error "You suck!"
end

var x [catch [throw-error] do
  io.write-error-line error-message
end]

var y [throw-error] ?? "You don't suck"

io.write-line y

let w [throw-error] ?? do 
  0
end do
  io.write-line w
end

var z [throw-error] !! do
  io.write-error-line "Ooof!!"
end

